---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Pasos de Tradición: Historia, memoria y emoción." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=EB+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
		
        <title>{title} | Pasos de Tradición</title>
	</head>
	<body class="bg-carbon text-marfil font-garamond antialiased overflow-x-hidden selection:bg-dorado selection:text-carbon">
        
        <div class="capa-textura"></div>
        
        <Navbar />

        <main>
			<slot />
		</main>
	</body>
</html>