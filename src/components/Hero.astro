---
---
<section class="relative w-full min-h-screen flex items-center justify-center overflow-hidden bg-carbon px-6 py-24 md:px-12 lg:px-24">
  
  <div id="canvas-container" class="absolute inset-0 z-0 opacity-60 mix-blend-screen pointer-events-none"></div>

  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_60%,rgba(197,160,89,0.12)_0%,rgba(10,10,10,0)_60%)] pointer-events-none z-10"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_20%,#0a0a0a_95%)] pointer-events-none z-10"></div>

  <div class="absolute inset-0 w-full h-full z-0 opacity-20 mix-blend-luminosity">
    <div class="w-full h-full bg-cover bg-center bg-no-repeat" style="background-image: url('/assets/images/hero-bg.jpg');"></div>
  </div>

  <div class="relative w-full max-w-5xl mx-auto flex flex-col items-center text-center z-20 space-y-8 md:space-y-12 mt-12">
    
    <div class="space-y-4">
      <h1 class="font-cinzel text-5xl md:text-7xl lg:text-8xl font-bold tracking-[0.15em] text-marfil uppercase texto-luminico animate-fade-in">
        Pasos de Tradición
      </h1>
      <p class="font-cormorant text-2xl md:text-3xl lg:text-4xl italic tracking-widest text-dorado/90 drop-shadow-[0_4px_8px_rgba(0,0,0,0.8)]">
        Historia, memoria y emoción
      </p>
    </div>

    <div class="w-24 h-[1px] bg-gradient-to-r from-transparent via-dorado to-transparent"></div>

    <div class="max-w-3xl mx-auto space-y-6">
      <p class="font-garamond text-xl md:text-2xl text-marfil/80 leading-relaxed text-justify md:text-center font-light drop-shadow-lg">
        En las calles adoquinadas de Santa Fe de Antioquia, los oficios de la Semana Santa no son simples rituales. 
        Son actos de transmisión: cuerpos que aprenden de otros cuerpos, manos que repiten gestos de generaciones anteriores.
      </p>
    </div>

    <div class="relative py-4 px-6 md:px-12 max-w-2xl border-l border-r border-dorado/20">
      <p class="font-cormorant text-xl md:text-2xl italic text-marfil/90 tracking-wide">
        “Los que hacen posible la procesión rara vez aparecen en las fotografías.”
      </p>
    </div>

  </div>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js"></script>
<script is:inline>
  let particles = [];

  function setup() {
    let canvas = createCanvas(windowWidth, windowHeight);
    canvas.parent('canvas-container');
    for (let i = 0; i < 80; i++) {
      particles.push(new Particle());
    }
  }

  function draw() {
    clear();
    for (let i = 0; i < particles.length; i++) {
      particles[i].update();
      particles[i].display();
    }
  }

  function windowResized() {
    resizeCanvas(windowWidth, windowHeight);
  }

  class Particle {
    constructor() {
      this.x = random(width);
      this.y = random(height);
      this.vx = random(-0.2, 0.2);
      this.vy = random(-0.5, -0.1); // Suben lentamente
      this.alpha = random(50, 200);
      this.size = random(1, 4);
      this.noiseOffsetX = random(1000);
    }

    update() {
      this.x += this.vx + (noise(this.noiseOffsetX) - 0.5) * 0.5;
      this.y += this.vy;
      this.noiseOffsetX += 0.01;
      
      // Si salen de la pantalla, vuelven abajo
      if (this.y < 0) {
        this.y = height;
        this.x = random(width);
      }
    }

    display() {
      noStroke();
      // Color dorado cálido
      fill(197, 160, 89, this.alpha * (sin(frameCount * 0.05 + this.noiseOffsetX) * 0.5 + 0.5));
      ellipse(this.x, this.y, this.size);
    }
  }
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 3s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; filter: blur(10px); transform: scale(0.95); }
    to { opacity: 1; filter: blur(0); transform: scale(1); }
  }
</style>