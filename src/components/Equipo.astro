---
const team = [
  {
    name: "Valentina Garzón Pérez",
    foto: "valentina",
    role: "Desarrollo narrativo y audiovisual — El Códice de los Pasos",
    description: "Participó en la construcción narrativa y audiovisual, la escritura del guion y secuencias mediante IA. Desarrolló la implementación técnica de chroma key en Unity y la arquitectura del sitio web."
  },
  {
    name: "Thomas Aguirre García",
    foto: "thomas",
    role: "Diseño de experiencia y planeador de narrativas — Cúpula de Legados",
    description: "A cargo del prototipado de interacciones en el domo y el desarrollo conceptual usando Blender y TouchDesigner, conectando narrativamente las experiencias."
  },
  {
    name: "Juan José Hoyos Peláez",
    foto: "hoyos",
    role: "Modelado 3D y diseño sonoro — Cúpula de Legados",
    description: "A cargo del modelado 3D del domo geodésico y la construcción del paisaje sonoro, integrando arquitectura efímera e inmersión acústica."
  },
  {
    name: "Juan José Machado Miranda",
    foto: "machado",
    role: "Conceptualización, puesta en escena y sonido — El Rastro de los Gestos",
    description: "A cargo de la conceptualización performática, dirección de movimientos, composición visual de las sombras y atmósfera auditiva del proyecto."
  },
  {
    name: "José Alzate",
    foto: "jose",
    role: "Post producción, edición y refinación de audio — El Rastro de los Gestos",
    description: "Consolidó la experiencia visual y auditiva mediante la edición, tratamiento visual de escenas y la mezcla de audio para fortalecer la inmersión."
  },
  {
    name: "Pascualtobias Rendon Giraldo",
    foto: "pascualtobias",
    role: "Desarrollo técnico e integración en Unity — El Códice de los Pasos",
    description: "A cargo de la programación del flujo interactivo en realidad aumentada, integración de elementos en Unity y testeo de prototipos en Android."
  }
];

team.sort((a, b) => a.name.localeCompare(b.name));
---
<section id="equipo" class="py-32 bg-carbon border-t border-marfil/10 relative z-10">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    
    <div class="text-center space-y-6 mb-20">
      <h2 class="font-cinzel text-3xl md:text-5xl text-dorado uppercase tracking-widest texto-luminico deslizar-arriba">Las manos detrás del proyecto</h2>
      <p class="font-garamond text-xl md:text-2xl text-marfil/70 max-w-2xl mx-auto deslizar-arriba retraso-1">
        Un colectivo interdisciplinario de estudiantes que explora nuevas formas de preservar la memoria y el patrimonio cultural.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {team.map((member, index) => (
        <div class={`group p-8 border border-marfil/10 bg-[#0a0a0a] hover:border-dorado/50 transition-colors duration-500 flex flex-col items-center space-y-4 deslizar-arriba retraso-${(index % 3) + 1}`}>
          
          <div class="w-24 h-24 rounded-full overflow-hidden border-2 border-dorado/30 flex-shrink-0">
            <img
              src={`/pasos-de-tradicion/assets/images/${member.foto}.jpeg`}
              alt={member.name}
              class="w-full h-full object-cover object-center"
            />
          </div>

          <h3 class="font-cinzel text-2xl md:text-3xl text-marfil tracking-wide text-center group-hover:texto-luminico transition-all duration-300">{member.name}</h3>

          <p class="font-inter text-sm md:text-base tracking-wider text-dorado/80 leading-relaxed text-center">{member.role}</p>

          <p class="font-garamond text-marfil/70 text-lg leading-relaxed text-justify pt-4 border-t border-marfil/10 w-full">
            {member.description}
          </p>

        </div>
      ))}
    </div>

    <div class="text-center mt-32 deslizar-arriba retraso-2">
      <p class="font-cormorant italic text-3xl text-dorado/80">
        "Toda memoria necesita manos que decidan preservarla."
      </p>
    </div>
  </div>
</section>